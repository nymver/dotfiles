#!/bin/bash


declare -A app_icons=(
    ["steam"]="%{F#C7D5E0}ï†¶ %{F-}"
    ["firefox"]="%{F#FF4400}ï‰© %{F-}"
    ["sublime"]="%{F#FFAA00}îڑ– %{F-}"
    ["prismlauncher"]="%{F#33FF33}َ°چ³ %{F-}"
    ["telegram"]="%{F#00AAFF}îˆ— %{F-}"
    ["chromium"]="%{F#669DF6}ï‰¨ %{F-}"
    ["pacman"]="%{F#FFFF00}َ°®¯ %{F-}"
    ["mocp"]="%{F#44BBFF}ï€پ %{F-}"
    ["python"]="%{F#FFFF00}îˆµ %{F-}"
    ["node"]="%{F#44FF44}َ°ژ™ %{F-}"
    ["quodlibet"]="%{F#AAAAAA}َ°½° %{F-}"
    ["lf"]="%{F#F6C177}ï““ %{F-}"
    ["wget"]="%{F#77C1F6}ïگ‰ %{F-}"
    ["vlc"]="%{F#FFB100}َ°•¼ %{F-}"
    ["gajim"]="%{F#77F6C1}َ°ں؟ %{F-}"
    ["htop"]="%{F#FF55AA}َ°—¶ %{F-}"
    ["Discord"]="%{F#7289DA}َ°™¯ %{F-}"
)


is_running() {
    pgrep "$1" > /dev/null
}


get_output() {
    output=""
    for app in "${!app_icons[@]}"; do
        if is_running "$app"; then
            output+=" ${app_icons[$app]} "
        fi
    done
    echo "$output"
}


get_output

